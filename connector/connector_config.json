{
  "name": "chatapp-outbox-events",
  "config": {
    "connector.class": "io.debezium.connector.oracle.OracleConnector",
    "tasks.max": "1",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",
    "database.hostname": "oracle-db",
    "database.port": "1521",
    "database.user": "C##DBZUSER",
    "database.password": "Dbz123",
    "database.dbname": "FREE",
    "database.pdb.name": "FREEPDB1",
    "database.server.name": "oracle-account",
    "database.connection.adapter": "logminer",
    "schema.include.list": "APPUSER",
    "table.include.list": "APPUSER.ACCOUNT_OUTBOX_EVENTS,APPUSER.ROOM_OUTBOX_EVENTS",
    "topic.prefix": "CHATAPP",
    "snapshot.mode": "no_data",
    "include.schema.changes": "false",
    "lob.enabled": "true",
    "decimal.handling.mode": "double",
    "skipped.operations": "u,d,t",
    "transforms": "unwrap,castNumeric,createKey,extractKey",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": "true",
    "transforms.unwrap.delete.handling.mode": "drop",
    "transforms.castNumeric.type": "org.apache.kafka.connect.transforms.Cast$Value",
    "transforms.castNumeric.spec": "ID:int64,VERSION:int64",
    "transforms.createKey.type": "org.apache.kafka.connect.transforms.ValueToKey",
    "transforms.createKey.fields": "AGGREGATE_ID",
    "transforms.extractKey.type": "org.apache.kafka.connect.transforms.ExtractField$Key",
    "transforms.extractKey.field": "AGGREGATE_ID",
    "schema.history.internal.store.only.captured.tables.ddl": "true",
    "schema.history.internal.store.only.captured.databases.ddl": "true",
    "schema.history.internal.kafka.bootstrap.servers": "kafka:9092",
    "schema.history.internal.kafka.topic": "__debezium.schema_history.chatapp"
  }
}