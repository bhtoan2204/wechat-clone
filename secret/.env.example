ENVIRONMENT=local
SERVER_PORT=35000

AUTH_TOKEN_ISSUER=your-app-name
AUTH_ACCESS_TOKEN_TTL_SECONDS=9000
AUTH_REFRESH_TOKEN_TTL_SECONDS=21600
AUTH_ACCESS_PUBLIC_KEY=YOUR_BASE64_ACCESS_PUBLIC_KEY
AUTH_ACCESS_PRIVATE_KEY=YOUR_BASE64_ACCESS_PRIVATE_KEY
AUTH_REFRESH_PUBLIC_KEY=YOUR_BASE64_REFRESH_PUBLIC_KEY
AUTH_REFRESH_PRIVATE_KEY=YOUR_BASE64_REFRESH_PRIVATE_KEY

REDIS_CONNECTION_URL=redis://:@localhost:6379/0
REDIS_POOL_SIZE=30
REDIS_DIAL_TIMEOUT_SECONDS=10
REDIS_READ_TIMEOUT_SECONDS=5
REDIS_WRITE_TIMEOUT_SECONDS=5
REDIS_IDLE_TIMEOUT_SECONDS=180
REDIS_MAX_IDLE_CONN_NUMBER=8
REDIS_MAX_ACTIVE_CONN_NUMBER=8

DB_DRIVER=oracle
DB_CONNECTION_URL=oracle://appuser:App123@localhost:1521/FREEPDB1
DB_MAX_OPEN_CONN_NUMBER=8
DB_MAX_IDLE_CONN_NUMBER=4
DB_CONN_MAX_LIFE_TIME_SECONDS=1800

KAFKA_SERVERS=localhost:29092
KAFKA_OFFSET_RESET=latest
KAFKA_NOTIFICATION_CONSUMER_GROUP=local-notification-v1
KAFKA_PAYMENT_CONSUMER_GROUP=local-payment-v1
KAFKA_LEDGER_CONSUMER_MESSAGING_GROUP=local-messaging-ledger-v1
KAFKA_LEDGER_CONSUMER_PROJECTION_GROUP=local-projection-ledger-v1
KAFKA_ROOM_CONSUMER_PROJECTION_GROUP=local-projection-room-v1
KAFKA_ROOM_CONSUMER_MESSAGING_GROUP=local-messaging-room-v1
KAFKA_CONSUMER_ACCOUNT_TOPIC=CHATAPP.APPUSER.ACCOUNT_OUTBOX_EVENTS
KAFKA_CONSUMER_PAYMENT_EVENTS_TOPIC=PAYMENT.APPUSER.PAYMENT_EVENTS
KAFKA_CONSUMER_PAYMENT_OUTBOX_TOPIC=PAYMENT.OUTBOX.EVENTS.V1
KAFKA_CONSUMER_ROOM_OUTBOX_TOPIC=CHATAPP.APPUSER.ROOM_OUTBOX_EVENTS
KAFKA_CONSUMER_LEDGER_OUTBOX_TOPIC=CHATAPP.APPUSER.LEDGER_OUTBOX_EVENTS

SECURITY_SECRET_KEY=q3r7Qq7b8kFZc4xq3G5P9aM2H2kX1n0p2x7yQm0Zc9Q=

# npx web-push generate-vapid-keys
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_TTL=30

CONSUL_ADDRESS=localhost:8500
CONSUL_SCHEME=http
CONSUL_DATA_CENTER=dc1
CONSUL_TOKEN=

# Stripe
LEDGER_STRIPE_PUBLIC_KEY=your-stripe-public-key
LEDGER_STRIPE_SECRET_KEY=your-stripe-secret-key
LEDGER_STRIPE_SUCCESS_URL=your-frontend-url/payment/success
LEDGER_STRIPE_CANCEL_URL=your-frontend-url/payment/failure
LEDGER_STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# MinIO
MINIO_ENDPOINT=localhost:9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=chat-media
MINIO_USE_SSL=false

# Cassandra
CASSANDRA_ENABLED=true
CASSANDRA_HOSTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=chat_app
CASSANDRA_USERNAME=
CASSANDRA_PASSWORD=
CASSANDRA_LOCAL_DC=dc1
CASSANDRA_CONSISTENCY=quorum
CASSANDRA_REPLICATION_CLASS=SimpleStrategy
CASSANDRA_REPLICATION_FACTOR=1
CASSANDRA_CONNECT_TIMEOUT_SECONDS=10
CASSANDRA_TIMEOUT_SECONDS=10

# Elasticsearch
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_ADDRESSES=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_ROOM_MESSAGE_INDEX=room_messages_v2
ELASTICSEARCH_CONNECT_TIMEOUT_SECONDS=10
ELASTICSEARCH_RESPONSE_HEADER_TIMEOUT_SECONDS=10

# Google Client
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CLIENT_REDIRECT_URL=your-redirect-url