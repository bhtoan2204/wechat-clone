{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Package",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/main.go",
      "envFile": "${workspaceFolder}/secret/.env",
      "cwd": "${workspaceFolder}",
      "args": ["DEBUG_PATH_ECHO=${workspaceFolder}"]
    }
  ]
}